# 이 파일을 .env.local로 복사하고 값을 채우세요.
# 또는 Claude Code에서 /setup-church 실행 시 자동으로 .env.local이 생성됩니다.

# ── Supabase (필수) ──
# Supabase Dashboard → Project Settings → API에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (필수 — 폼 알림 메일 발송) ──
# https://resend.com/api-keys 에서 발급
RESEND_API_KEY=

# 발신 주소 (선택). 검증된 도메인 사용 권장.
# 예: "샘플교회 <noreply@example-church.kr>"
# 미설정 시 onboarding@resend.dev 사용 (스팸함 분류 가능성 있음).
RESEND_FROM=

# 알림 받을 관리자 이메일 (선택, 미설정 시 admin_users 테이블의 첫 admin 이메일로 발송)
RESEND_TO=

# ── 사이트 URL (필수) ──
# 로컬: http://localhost:3000
# 프로덕션 (Vercel): https://<project>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
