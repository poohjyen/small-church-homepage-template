# 이 파일을 .env.local로 복사하고 값을 채우세요.
# 또는 Claude Code에서 /setup-church 실행 시 자동으로 .env.local이 생성됩니다.

# ── Supabase (필수) ──
# Supabase Dashboard → Project Settings → API에서 복사
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend (필수 — 폼 알림 메일 발송) ──
# https://resend.com/api-keys 에서 발급
RESEND_API_KEY=

# 발신 주소 (선택). 검증된 도메인 사용 권장.
# 예: "샘플교회 <noreply@example-church.kr>"
# 미설정 시 onboarding@resend.dev 사용 (스팸함 분류 가능성 있음).
RESEND_FROM=

# 알림 받을 관리자 이메일 (선택, 미설정 시 admin_users 테이블의 첫 admin 이메일로 발송)
RESEND_TO=

# ── 사이트 URL (필수) ──
# 로컬: http://localhost:3000
# 프로덕션 (Vercel): https://<project>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════
# 아래는 모두 "선택" — 키가 없으면 해당 기능만 자동으로 꺼집니다.
# 운영하면서 필요한 기능만 발급해 등록하세요.
# ════════════════════════════════════════════════════════════

# ── 유튜브 자동 동기화 (선택) ──
# Google Cloud Console → YouTube Data API v3 키. 재생목록 ID는 admin > 설정에서 입력.
YOUTUBE_API_KEY=

# ── AI 주보 자동 분석 / Gemini (선택) ──
# Google AI Studio(https://aistudio.google.com/apikey)에서 발급. 무료 티어 가능.
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Cloudflare Turnstile 캡차 (선택 — 공개 폼 봇 방어) ──
# https://dash.cloudflare.com → Turnstile 에서 사이트 추가 후 발급.
# 둘 다 비우면 캡차 미표시 + 서버 검증 우회(개발 편의). 운영 시 등록 권장.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Sentry 에러 모니터링 (선택) ──
# https://sentry.io → 프로젝트 DSN. 미설정 시 SDK no-op(안전).
NEXT_PUBLIC_SENTRY_DSN=
# 소스맵 업로드까지 원하면 (선택):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
